# Copy to terraform.tfvars and fill in real values. Do NOT commit terraform.tfvars.

project_id      = "my-gemini-agent-project"
organization_id = "123456789012"
region          = "us-central1"

# ---- Okta ----
okta_issuer_uri = "https://your-org.okta.com/oauth2/default"
okta_client_id  = "0oaEXAMPLEokta1234"

# ---- Microsoft Entra ID (Azure AD) ----
azuread_tenant_id = "00000000-0000-0000-0000-000000000000"
azuread_client_id = "11111111-1111-1111-1111-111111111111"

# ---- Agent ----
agent_name        = "gemini-support-agent"
workforce_pool_id = "agent-gateway-workforce"
workload_pool_id  = "agent-gateway-workload"
